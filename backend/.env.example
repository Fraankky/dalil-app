# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dalil
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/dalil

# Redis
REDIS_URL=redis://localhost:6379/0

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384
EMBEDDING_BATCH_SIZE=32

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# App
ENV=development  # set to "production" for prod
DEBUG=false  # set true only for staging
CORS_ORIGINS=http://localhost:3000
API_PREFIX=/api/v1
SEARCH_DEFAULT_LIMIT=10
SEARCH_MAX_LIMIT=50
SEARCH_MIN_SCORE=0.3

# PROD: set DEBUG=false, ENV=production, strong POSTGRES_PASSWORD,
# CORS_ORIGINS=https://yourdomain.tld, DATABASE_URL with ?sslmode=require on the SYNC url
