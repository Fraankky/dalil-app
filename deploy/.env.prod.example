# Replace CHANGE_ME with a strong POSTGRES_PASSWORD;
# keep DATABASE_URL / DATABASE_URL_SYNC / POSTGRES_PASSWORD consistent.
DATABASE_URL=postgresql+asyncpg://dalil:CHANGE_ME@db:5432/dalil
DATABASE_URL_SYNC=postgresql://dalil:CHANGE_ME@db:5432/dalil
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384
EMBEDDING_BATCH_SIZE=32
ENV=production
DEBUG=false
CORS_ORIGINS=https://yourdomain.tld
API_PREFIX=/api/v1
SEARCH_DEFAULT_LIMIT=10
SEARCH_MAX_LIMIT=50
SEARCH_MIN_SCORE=0.3
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
POSTGRES_PASSWORD=CHANGE_ME_strong_password
DOMAIN=yourdomain.tld
LETSENCRYPT_EMAIL=you@example.com