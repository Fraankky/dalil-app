# ============================================================
# .env.prod — Dalil production secrets (JANGAN COMMIT)
# ============================================================
# Ganti semua CHANGE_ME dengan password random >= 24 karakter.
# Konsistensi password WAJIB:
#   - POSTGRES_PASSWORD == password di DATABASE_URL & DATABASE_URL_SYNC
#   - REDIS_PASSWORD    == password di REDIS_URL, CELERY_BROKER_URL, CELERY_RESULT_BACKEND
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=dalil
POSTGRES_DB=dalil
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Database URLs (password harus sama dengan POSTGRES_PASSWORD) ---
DATABASE_URL=postgresql+asyncpg://dalil:CHANGE_ME_STRONG_PASSWORD@db:5432/dalil
DATABASE_URL_SYNC=postgresql://dalil:CHANGE_ME_STRONG_PASSWORD@db:5432/dalil
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
# Set true jika pakai Postgres eksternal/managed (Railway, Aiven).
# Biarkan false untuk Postgres Docker internal (satu host).
DB_SSL=false

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
REDIS_URL=redis://:CHANGE_ME_STRONG_PASSWORD@redis:6379/0

# --- Celery (password = REDIS_PASSWORD; pakai DB Redis berbeda) ---
CELERY_BROKER_URL=redis://:CHANGE_ME_STRONG_PASSWORD@redis:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_STRONG_PASSWORD@redis:6379/2

# --- Embedding ---
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384
EMBEDDING_BATCH_SIZE=32

# --- App config ---
ENV=production
DEBUG=false
CORS_ORIGINS=https://yourdomain.pages.dev
API_PREFIX=/api/v1
SEARCH_DEFAULT_LIMIT=10
SEARCH_MAX_LIMIT=50
SEARCH_MIN_SCORE=0.3

# --- Domain & TLS ---
DOMAIN=api.yourdomain.tld
LETSENCRYPT_EMAIL=admin@yourdomain.tld

# --- Health check token (untuk akses /readyz, tanpa ini /readyz return 403) ---
HEALTH_TOKEN=CHANGE_ME_HEALTH_TOKEN

# --- Backup script (opsional, defaultnya ditampilkan) ---
# Dipakai oleh deploy/backup.sh. Kosongkan ENCRYPT_KEY jika tidak butuh GPG.
DB_NAME=dalil
DB_USER=dalil
BACKUP_DIR=/backups
RETENTION_DAYS=14
ENCRYPT_KEY=